# ============================================
# AI Employee Operating System - Environment
# ============================================

# Application
APP_NAME="AI Employee OS"
APP_ENV=development
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ai_eos
DB_USER=eos_user
DB_PASSWORD=eos_password_2024
DATABASE_URL=mysql+pymysql://eos_user:eos_password_2024@mysql:3306/ai_eos

# AI Provider (groq or ollama)
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# Company
COMPANY_NAME=TechCorp Solutions Pvt. Ltd.
COMPANY_ADDRESS=123 Tech Park, Bangalore, Karnataka 560001
COMPANY_EMAIL=hr@techcorp.com
COMPANY_PHONE=+91-80-12345678
COMPANY_CIN=U72200KA2010PTC054321

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
BCRYPT_ROUNDS=12
